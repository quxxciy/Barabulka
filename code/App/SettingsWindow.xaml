<Window x:Class="Barabulka2.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки Barabulka2"
        Height="440" Width="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="True">
    <StackPanel Margin="18">
        <TextBlock Text="Прозрачность рыб" FontWeight="Bold" Margin="0,0,0,6"/>
        <DockPanel LastChildFill="True" Margin="0,0,0,16">
            <TextBlock x:Name="OpacityLabel" Text="100%" Width="42" DockPanel.Dock="Right" TextAlignment="Right"/>
            <Slider x:Name="OpacitySlider"
                    Minimum="0.1" Maximum="1.0" Value="1.0"
                    TickFrequency="0.05" IsSnapToTickEnabled="True"
                    ValueChanged="OpacitySlider_ValueChanged"/>
        </DockPanel>

        <TextBlock Text="FPS рыб" FontWeight="Bold" Margin="0,0,0,6"/>
        <ComboBox x:Name="FpsComboBox"
                  SelectionChanged="FpsComboBox_SelectionChanged"
                  Margin="0,0,0,16">
            <ComboBoxItem Content="30"/>
            <ComboBoxItem Content="60"/>
            <ComboBoxItem Content="144"/>
            <ComboBoxItem Content="Неограниченно"/>
        </ComboBox>

        <TextBlock Text="Количество рыб" FontWeight="Bold" Margin="0,0,0,6"/>
        <DockPanel LastChildFill="True" Margin="0,0,0,16">
            <TextBlock x:Name="FishCountLabel" Text="50" Width="42" DockPanel.Dock="Right" TextAlignment="Right"/>
            <Slider x:Name="FishCountSlider"
                    Minimum="5" Maximum="200" Value="50"
                    TickFrequency="5" IsSnapToTickEnabled="True"
                    ValueChanged="FishCountSlider_ValueChanged"/>
        </DockPanel>

        <TextBlock Text="Скорость рыб" FontWeight="Bold" Margin="0,0,0,6"/>
        <DockPanel LastChildFill="True" Margin="0,0,0,16">
            <TextBlock x:Name="SpeedLabel" Text="100%" Width="42" DockPanel.Dock="Right" TextAlignment="Right"/>
            <Slider x:Name="SpeedSlider"
                    Minimum="0.25" Maximum="3.0" Value="1.0"
                    TickFrequency="0.05" IsSnapToTickEnabled="True"
                    ValueChanged="SpeedSlider_ValueChanged"/>
        </DockPanel>
        <TextBlock Text="Случайный разброс скорости у каждой рыбы сохраняется всегда - это множитель поверх него."
                   TextWrapping="Wrap" FontSize="11" Foreground="Gray" Margin="0,0,0,16"/>

        <CheckBox x:Name="ClickThroughCheckBox"
                  Content="Клики проходят сквозь рыб (окно неинтерактивно)"
                  Checked="ClickThroughCheckBox_Changed"
                  Unchecked="ClickThroughCheckBox_Changed"
                  Margin="0,0,0,4"/>
        <TextBlock Text="Если выключить - окно с рыбами начнёт перехватывать клики мыши по всему экрану."
                   TextWrapping="Wrap" FontSize="11" Foreground="Gray" Margin="0,0,0,16"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Закрыть" Width="90" Click="CloseButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
